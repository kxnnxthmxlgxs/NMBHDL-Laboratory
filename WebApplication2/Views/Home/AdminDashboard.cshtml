@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Admin Dashboard</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="~/css/dashboardstyles.css" rel="stylesheet" />
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">

        
        <div class="sidebar-top">
            <div class="sidebar-profile">
                <i class="fa-solid fa-user"></i>

                <div class="profile-info">
                    <div class="profile-text">Mr</div>
                    <div class="profile-text">Karabo Modau</div>
                </div>
            </div>

            <div class="profile-role">
                Administrator
            </div>

        </div>

       
        
        <div class="sidebar-bottom">
          
            <a href="#"
               class="sidebar-link ajax-link"
               data-url="@Url.Action("AddMedicalConditions", "Admin")">
                <i class="fa-solid fa-virus"></i> Medical Conditions
            </a>

            <a href="#"
               class="sidebar-link ajax-link"
               data-url="@Url.Action("AddAllergies", "Admin")">
                <i class="fa-solid fa-hand-dots"></i> Allergies
            </a>

            <a href="#"
               class="sidebar-link ajax-link"
               data-url="@Url.Action("AddMedication", "Admin")">
                <i class="fa-solid fa-capsules"></i> Medication
            </a>

            

            <div class="sidebar-actions">

                <a asp-controller="" asp-action="" class="sidebar-alert-btn">
                    <i class="fa-solid fa-user-gear"></i> Profile Settings
                </a>

                <a asp-controller="" asp-action="" class="sidebar-primary-btn">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </a>

            </div>

        </div>

    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content" id="mainContent">
        
    </div>

    <!-- AJAX CONTENT LOADER -->
    <script>

        document.addEventListener("DOMContentLoaded", function () {

            document.querySelectorAll(".ajax-link").forEach(link => {

                link.addEventListener("click", function (e) {

                    e.preventDefault(); // STOP FULL PAGE REFRESH

                    const url = this.dataset.url;

                    fetch(url)
                        .then(res => res.text())
                        .then(html => {

                            document.getElementById("mainContent").innerHTML = html;

                        });

                });

            });

        });

    </script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>