@model List<dynamic>

<div class="container-fluid p-4 text-start rounded" style="color: #ffffff; background-color: #071D37;">
    
    <div class="mb-4">
        <h2 class="fw-bold mb-1"><i class="fa-solid fa-list-check me-2 text-primary"></i>Specimen Workflow Tracker</h2>
        <p class="text-white-50 m-0 small">Monitor pathology processing lifecycles, view printable patient reports, or manage cancellations according to core business rule validations.</p>
    </div>

    <div class="p-4" style="background-color: #051425; border: 1px solid #16406d; border-radius: 14px;">
        <div class="table-responsive">
            <table class="table table-hover m-0 align-middle" style="background-color: #051425; border-color: #16406d;">
                <thead>
                    <tr class="text-white-50" style="border-bottom: 2px solid #16406d; font-size: 14px;">
                        <th>Requisition ID</th>
                        <th>Patient Entity</th>
                        <th>Investigation Profiles</th>
                        <th>Created Timestamp</th>
                        <th>Urgency Index</th>
                        <th>Processing Pipeline Status</th>
                        <th class="text-center">Operational Actions</th>
                    </tr>
                </thead>
                <tbody style="font-size: 13px;">
                    @foreach (var order in Model)
                    {
                        string urgencyClass = order.Urgency == "STAT" ? "bg-danger" : order.Urgency == "Urgent" ? "bg-warning text-dark" : "bg-info text-dark";
                        string statusClass = "bg-secondary";

                        if (order.Status == "Submitted") statusClass = "bg-secondary opacity-75";
                        else if (order.Status == "Sample(s) Received") statusClass = "bg-warning text-dark";
                        else if (order.Status == "In Progress") statusClass = "bg-primary";
                        else if (order.Status == "Completed") statusClass = "bg-success";
                        else if (order.Status == "Released by doctor") statusClass = "bg-info text-dark";

                        // Business Rule Check: Cancellation is allowed ONLY if status is Submitted or Sample(s) Received
                        bool canCancel = (order.Status == "Submitted" || order.Status == "Sample(s) Received");
                        bool isCompleted = (order.Status == "Completed" || order.Status == "Released by doctor");

                        <tr>
                            <td class="fw-bold text-white-50">REQ-#@order.RequestId</td>
                            <td>
                                <div class="fw-bold text-white">@order.PatientName</div>
                                <small class="text-white-50" style="font-size: 11px;">ID: @order.IdNumber</small>
                            </td>
                            <td>@order.Panels</td>
                            <td class="text-white-50">@order.DateCreated</td>
                            <td><span class="badge @urgencyClass px-2">@order.Urgency</span></td>
                            <td><span class="badge @statusClass px-2">@order.Status</span></td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    
                                    @if (isCompleted)
                                    {
                                        <a href="/Home/DownloadPatientReportPdf?requestId=@order.RequestId" target="_blank" class="btn btn-sm btn-success px-2 fw-semibold">
                                            <i class="fa-solid fa-file-pdf me-1"></i> View PDF
                                        </a>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-secondary px-2" disabled style="cursor: not-allowed; opacity: 0.3;">
                                            <i class="fa-solid fa-clock me-1"></i> Pending Results
                                        </button>
                                    }

                                    @if (canCancel)
                                    {
                                        <button class="btn btn-sm btn-outline-danger px-2" onclick="processOrderCancellation(@order.RequestId, '@order.Status')">
                                            <i class="fa-solid fa-ban me-1"></i> Cancel
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-secondary px-2" disabled style="cursor: not-allowed; opacity: 0.3;" title="System Rule: Cannot cancel orders currently under processing pipeline evaluation.">
                                            <i class="fa-solid fa-lock me-1"></i> Locked
                                        </button>
                                    }

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    function processOrderCancellation(id, currentStatus) {
        const checkConfirmation = confirm(`Are you sure you want to cancel Diagnostic Batch REQ-#${id}?\n\nSystem verification confirmed status is currently: [${currentStatus}], which meets system validation parameters.`);
        
        if (checkConfirmation) {
            alert(`Success: Requisition Order REQ-#${id} has been formally cancelled and deleted from active specimen queues.`);
            // Reload the view snippet automatically to simulate refreshing data state changes
            loadSection('trackprogress');
        }
    }
</script>