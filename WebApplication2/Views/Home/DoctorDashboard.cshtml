@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Doctor Dashboard</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="~/css/dashboardstyles.css" rel="stylesheet" />

    <style>
            .sidebar-heading {
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 1px;
                color: #727b84;
                font-weight: 700;
                padding: 12px 20px 4px 20px;
                margin: 0;
            }

            .animate-slide-in-toast {
                animation: toastSlideIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
            }
            @@keyframes toastSlideIn {
                from {
                    transform: translateX(100%);
                    opacity: 0;
                }

                to {
                    transform: translateX(0);
                    opacity: 1;
                }
            }

            .app-container {
                display: flex;
                height: 100vh;
                overflow: hidden;
                background-color: #ffffff;
            }

            .sidebar-link {
                display: flex;
                align-items: center;
                padding: 10px 20px !important;
                color: #ffffff !important;
                text-decoration: none;
                font-size: 0.92rem;
                transition: all 0.2s;
            }

                .sidebar-link:hover, .sidebar-link.active {
                    background-color: #0c2b4e;
                    font-weight: 600;
                }
    </style>
</head>
<body>

    <div class="app-container">

        <div class="sidebar" style="width: 260px; background-color: #071D37; display: flex; flex-direction: column; height: 100vh;">

            <div style="flex-shrink: 0;">
                <div class="sidebar-top" style="padding: 20px 20px 10px 20px; display: flex; align-items: center; gap: 15px; text-align: left;">
                    <div class="profile-avatar" style="width: 42px; height: 42px; background: #ffffff; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #071D37;">
                        <i class="fa-solid fa-user" style="font-size: 20px;"></i>
                    </div>

                    <div class="profile-info">
                        <div class="profile-text" style="font-size: 0.82rem; color: #8da4be; margin-bottom: -2px;">Mr</div>
                        <div class="profile-text" style="font-size: 0.92rem; font-weight: 600; color: #ffffff; line-height: 1.2;">Kenneth Malgas</div>
                    </div>
                </div>

                <div style="font-size: 1.6rem; font-weight: 500; color: #ffffff; padding: 0 20px 15px 20px; border-bottom: 2px solid #ffffff; letter-spacing: 0.5px;">
                    Doctor
                </div>
            </div>

            <div class="sidebar-bottom" style="flex: 1; overflow-y: auto; padding-top: 5px;">

                <div class="sidebar-heading">Patients</div>

                <a href="javascript:void(0)" onclick="loadSection('managepatients')" class="sidebar-link">
                    <i class="fa-solid fa-user-doctor me-2" style="width: 20px;"></i> Patient Search
                </a>

                <a href="javascript:void(0)" onclick="loadSection('createrequest')" class="sidebar-link">
                    <i class="fa-solid fa-hand-holding-medical me-2" style="width: 20px;"></i> New Test Request
                </a>

                <div class="sidebar-heading">Results</div>

                <a href="javascript:void(0)" onclick="loadSection('alerts')" class="sidebar-link">
                    <i class="fa-solid fa-chart-pie me-2" style="width: 20px;"></i> Dashboard
                </a>

                <a href="javascript:void(0)" onclick="loadSection('trackprogress')" class="sidebar-link">
                    <i class="fa-solid fa-prescription-bottle-medical me-2" style="width: 20px;"></i> All Results
                </a>

                <div class="sidebar-heading">Systems</div>

                <a href="javascript:void(0)" onclick="loadSection('reports')" class="sidebar-link">
                    <i class="fa-solid fa-file-pdf me-2" style="width: 20px;"></i> Doctor Reports
                </a>

            </div>

            <div style="flex-shrink: 0; padding: 15px; display: flex; flex-direction: column; gap: 8px; border-top: 1px solid #16406d; background-color: #071D37;">
                <button onclick="loadSection('profilesettings')" class="btn sidebar-link w-100 d-flex align-items-center justify-content-center gap-2 fw-semibold text-white" style="background-color: #dc3545; border: none; padding: 10px; border-radius: 6px; font-size: 0.9rem;">
                    <i class="fa-solid fa-user-gear"></i> Profile Settings
                </button>

                <a asp-controller="Home" asp-action="LoginPage" class="btn w-100 d-flex align-items-center justify-content-center gap-2 fw-semibold text-white" style="background-color: #007bff; border: none; padding: 10px; border-radius: 6px; font-size: 0.9rem; text-decoration: none;">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </a>
            </div>

        </div>

        <div class="main-content overflow-auto flex-grow-1" id="mainContent" style="min-height: 100vh; background-color: #ffffff;">
            <div class="d-flex justify-content-center align-items-center h-100 py-5">
                <div class="text-center text-secondary">
                    <i class="fa-solid fa-circle-notch fa-spin fs-3 mb-2 text-primary"></i>
                    <p class="m-0">Loading Clinical Stream...</p>
                </div>
            </div>
        </div>

    </div>

    <div id="toastContainer" class="position-fixed top-0 end-0 p-3" style="z-index: 3000; margin-top: 10px;"></div>

    <script>
            function loadSection(section) {
                // Remove active status highlights from sidebar list views
                document.querySelectorAll('.sidebar-link').forEach(link => {
                    link.classList.remove('active');
                });

                // Attach custom highlighting tracking on current target selection
                const clickedElement = window.event?.currentTarget;
                if (clickedElement) {
                    clickedElement.classList.add('active');
                } else {
                    let targetSelector = `[onclick="loadSection('${section}')"]`;
                    const defaultLink = document.querySelector(targetSelector);
                    if (defaultLink) defaultLink.classList.add('active');
                }

                // Fetch dynamic subviews asynchronously
                fetch('/Home/LoadDashboardSection?section=' + section)
                    .then(res => res.text())
                    .then(html => {
                        document.getElementById("mainContent").innerHTML = html;
                    })
                    .catch(err => console.error("Could not fetch the sub-panel segment view:", err));
            }

            function showToast(title, message, type = 'success') {
                const container = document.getElementById('toastContainer');
                let accentColor = '#10b981';
                let icon = 'fa-circle-check';

                if (type === 'danger') {
                    accentColor = '#ef4444';
                    icon = 'fa-circle-xmark';
                } else if (type === 'warning') {
                    accentColor = '#f59e0b';
                    icon = 'fa-triangle-exclamation';
                }

                const toast = document.createElement('div');
                toast.className = "animate-slide-in-toast";
                toast.style = `
                    width: 320px;
                    background: #071D37;
                    border-left: 4px solid ${accentColor};
                    border: 1px solid #16406d;
                    color: white;
                    padding: 12px;
                    margin-bottom: 10px;
                    border-radius: 8px;
                    box-shadow: 0 8px 20px rgba(0,0,0,0.4);
                    display: flex;
                    align-items: flex-start;
                    gap: 10px;
                `;

                toast.innerHTML = `
                    <i class="fa-solid ${icon} fs-5" style="color: ${accentColor}; margin-top: 2px;"></i>
                    <div style="flex: 1;">
                        <div style="font-weight: 600; font-size: 0.88rem; margin-bottom: 1px;">${title}</div>
                        <div style="font-size: 0.78rem; color: #b4c6dc; line-height: 1.3;">${message}</div>
                    </div>
                    <button onclick="this.parentElement.remove()" style="background:none; border:none; color:#8da4be; font-size:12px; cursor:pointer;"><i class="fa-solid fa-xmark"></i></button>
                `;

                container.appendChild(toast);

                setTimeout(() => {
                    toast.style.opacity = '0';
                    toast.style.transform = 'translateX(50px)';
                    toast.style.transition = 'all 0.3s ease';
                    setTimeout(() => toast.remove(), 300);
                }, 4000);
            }

            document.addEventListener("DOMContentLoaded", function() {
                loadSection('alerts');
            });
    </script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body></html>