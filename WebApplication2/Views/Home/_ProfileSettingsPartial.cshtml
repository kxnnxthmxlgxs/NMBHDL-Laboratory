<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark m-0" style="letter-spacing: -0.5px;">Profile Settings</h2>
            <p class="text-muted m-0">Manage your clinical practitioner profile details and security credentials.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-8 col-lg-7">
            <div class="card border-0 shadow-sm p-4" style="border-radius: 12px; background: #ffffff;">
                <h5 class="fw-bold text-dark mb-3"><i class="fa-solid fa-user-md text-primary me-2"></i>Personal Information</h5>

                <form id="profileSettingsForm" onsubmit="event.preventDefault(); showToast('Profile Updated', 'Your practitioner account details have been successfully saved.', 'success');">
                    <div class="row g-3">
                        <div class="col-md-2">
                            <label class="form-label fw-semibold text-secondary small">Title</label>
                            <input type="text" class="form-control bg-light border-0" value="Mr" readonly style="padding: 10px; border-radius: 6px;" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label fw-semibold text-secondary small">Full Name</label>
                            <input type="text" class="form-control bg-light border-0" value="Kenneth" readonly style="padding: 10px; border-radius: 6px;" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label fw-semibold text-secondary small">Surname</label>
                            <input type="text" class="form-control bg-light border-0" value="Malgas" readonly style="padding: 10px; border-radius: 6px;" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-dark small">Contact Number</label>
                            <input type="tel" class="form-control border-secondary-subtle" value="0712345678" placeholder="e.g. 0812345678" required style="padding: 10px; border-radius: 6px;" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-dark small">Email Address</label>
                            <input type="email" class="form-control border-secondary-subtle" value="kenneth.malgas@nmbh-labs.co.za" placeholder="name@example.com" required style="padding: 10px; border-radius: 6px;" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-secondary small">HPCSA Registration Number</label>
                            <input type="text" class="form-control bg-light border-0" value="MED00392811" readonly style="padding: 10px; border-radius: 6px;" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-secondary small">Assigned Facility Role</label>
                            <input type="text" class="form-control bg-light border-0" value="Clinical Practitioner (Doctor)" readonly style="padding: 10px; border-radius: 6px;" />
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary px-4 fw-semibold d-flex align-items-center gap-2" style="padding: 10px; border-radius: 6px;">
                            <i class="fa-solid fa-floppy-disk"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-xl-4 col-lg-5">
            <div class="card border-0 shadow-sm p-4" style="border-radius: 12px; background: #ffffff;">
                <h5 class="fw-bold text-dark mb-3"><i class="fa-solid fa-shield-halved text-danger me-2"></i>Security & Credentials</h5>

                <form id="securitySettingsForm" onsubmit="event.preventDefault(); document.getElementById('currPass').value=''; document.getElementById('newPass').value=''; showToast('Credentials Updated', 'Your portal entry password access key has been successfully altered.', 'success');">
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-dark small">Current Password</label>
                        <input type="password" id="currPass" class="form-control border-secondary-subtle" required style="padding: 10px; border-radius: 6px;" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-dark small">New Password</label>
                        <input type="password" id="newPass" class="form-control border-secondary-subtle" required style="padding: 10px; border-radius: 6px;" />
                    </div>

                    <button type="submit" class="btn btn-outline-danger w-100 fw-semibold d-flex align-items-center justify-content-center gap-2 mt-2" style="padding: 10px; border-radius: 6px;">
                        <i class="fa-solid fa-key"></i> Update Access Key
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>