@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Lab Manager Dashboard</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="~/css/dashboardstyles.css" rel="stylesheet" />
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">

        
        <div class="sidebar-top">
            <div class="sidebar-profile">
                <i class="fa-solid fa-user"></i>

                <div class="profile-info">
                    <div class="profile-text">Mr</div>
                    <div class="profile-text">Jodi Cunningham</div>
                </div>
            </div>

            <div class="profile-role">
                Lab Manager
            </div>

        </div>

       
        
        <div class="sidebar-bottom">

            <a asp-controller="Home" asp-action="Index" class="sidebar-link">
                Dashboard
            </a>

            <a asp-controller="Admin" asp-action="Users" class="sidebar-link">
                Users
            </a>

            <a asp-controller="Admin" asp-action="Reports" class="sidebar-link">
                Reports
            </a>

            <a asp-controller="Admin" asp-action="Settings" class="sidebar-link">
                Settings
            </a>

            <div class="sidebar-actions">

                <a asp-controller="" asp-action="" class="sidebar-alert-btn">
                    <i class="fa-solid fa-user-gear"></i> Profile Settings
                </a>

                <a asp-controller="" asp-action="" class="sidebar-primary-btn">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </a>

            </div>

        </div>

    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content" id="mainContent">
        
    </div>

    <!-- AJAX CONTENT LOADER -->
    <script>
            function loadSection(section) {

                fetch('/Home/LoadDashboardSection?section=' + section)
                    .then(res => res.text())
                    .then(html => {
                        document.getElementById("mainContent").innerHTML = html;
                    });

            }
    </script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>